{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "SlimsteMensTimerServer",
    "description": "REST API collection for the SlimsteMensTimer server.\n\nRun requests in order for a full integration test:\n1. Create Session\n2. Register Player 1\n3. Register Player 2\n4. Start Session\n5. Update Score (Player 1)\n6. Heartbeat (Player 1)\n7. Get Players\n8. Delete Session\n\nCollection variables `sessionId` and `playerId` are set automatically by test scripts.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string",
      "description": "Base URL of the server. Change to the LAN address (e.g. http://192.168.1.5:5000) for device testing."
    },
    {
      "key": "sessionId",
      "value": "",
      "type": "string",
      "description": "Set automatically by the Create Session request."
    },
    {
      "key": "playerId",
      "value": "",
      "type": "string",
      "description": "Set automatically by the Register Player 1 request."
    },
    {
      "key": "playerId2",
      "value": "",
      "type": "string",
      "description": "Set automatically by the Register Player 2 request."
    }
  ],
  "item": [
    {
      "name": "Sessions",
      "item": [
        {
          "name": "Create Session",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Response has sessionId and joinUrl', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('sessionId');",
                  "    pm.expect(json).to.have.property('joinUrl');",
                  "    pm.collectionVariables.set('sessionId', json.sessionId);",
                  "    console.log('Session created:', json.sessionId);",
                  "    console.log('Join URL:', json.joinUrl);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/sessions",
              "host": ["{{baseUrl}}"],
              "path": ["api", "sessions"]
            }
          },
          "response": []
        },
        {
          "name": "Get Session",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Session state is returned', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('state');",
                  "    console.log('Session state:', json.state);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/sessions/{{sessionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "sessions", "{{sessionId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Start Session",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('State is Active', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.state).to.eql('Active');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/sessions/{{sessionId}}/start",
              "host": ["{{baseUrl}}"],
              "path": ["api", "sessions", "{{sessionId}}", "start"]
            }
          },
          "response": []
        },
        {
          "name": "Delete Session",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 204', () => pm.response.to.have.status(204));"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/sessions/{{sessionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "sessions", "{{sessionId}}"]
            }
          },
          "response": []
        }
      ]
    },
