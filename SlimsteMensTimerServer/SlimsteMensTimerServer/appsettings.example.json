{
  // The URL(s) the server listens on.
  // Change the port number if 5000 is already in use on your machine.
  // To listen on all network interfaces (required for LAN play), keep 0.0.0.0.
  "Urls": "http://0.0.0.0:5000",

  "GameSettings": {

    // Seconds without a heartbeat before a player is shown as disconnected
    // on the scoreboard. Increase this on unstable Wi-Fi networks.
    // Default: 30
    "StaleSeconds": 30,

    // Hours of inactivity before a session is automatically ended and removed.
    // Default: 2
    "SessionTimeoutHours": 2,

    // Maximum number of players that may join a single session.
    // Players who try to join a full session receive an error message.
    // Default: 8
    "MaxPlayersPerSession": 8
  }
}
